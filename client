int sendPublicKey(int dasSocket, std::string publicKeyString) {
    int publicSend = send(dasSocket, publicKeyString.c_str(), publicKeyString.length(), 0);
    if (publicSend < 0) {
        std::cout << "Fehler beim senden des public Keys!\n";
        return -1;
    }
}

int recoverPublicKey(char* publicKeyBuffer, int dasSocket) {
    int keyRecv = recv(dasSocket, publicKeyBuffer, 8192, 0);
    if (keyRecv < 0) {
        std::cout << "Fehler beim recovern des public Keys!\n";
        return -1;
    }

    std::cout << "\n PUBLIC KEY (anderer Client): " << std::string(publicKeyBuffer, keyRecv) << "\n";
}

